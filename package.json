{
  "name": "tivri",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "clean": "rimraf web/assets/dist",
    "build:css": "tailwindcss -i web/assets/css/input.css -o web/assets/css/theme.css",
    "build:js": "esbuild web/assets/js/app.js web/assets/js/admin.js web/assets/css/theme.css --bundle --minify \"--external:/assets/*\" --outdir=web/assets/dist \"--entry-names=[dir]/[name]-[hash]\" --metafile=web/assets/dist/manifest.json",
    "build": "bun run clean && bun run build:css && bun run build:js && rimraf web/assets/css/theme.css",
    "format": "prettier --write \"web/assets/js/**/*.js\""
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.3.3",
    "esbuild": "^0.28.1",
    "prettier": "^3.9.5",
    "rimraf": "^6.1.3",
    "tailwindcss": "^4.3.3"
  },
  "allowScripts": {
    "esbuild": true,
    "@parcel/watcher": true
  }
}
