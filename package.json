{
  "scripts": {
    "build:css": "tailwindcss -i web/assets/css/input.css -o web/assets/dist/css/theme.css",
    "build:js": "esbuild web/assets/js/app.js --bundle --minify --outfile=web/assets/dist/js/app.min.js",
    "build": "npm run build:css && npm run build:js",
    "format": "prettier --write \"web/assets/js/**/*.js\""
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.3.2",
    "esbuild": "^0.28.1",
    "prettier": "^3.9.5",
    "tailwindcss": "^4.3.2"
  },
  "allowScripts": {
    "esbuild": true,
    "@parcel/watcher": true
  }
}
