# ==========================================
# 🌍 ENVIRONMENT DIRECTIVES
# ==========================================
# Set to "development" for local live-reloading, or "production" for the final build.
APP_ENV=production

# ==========================================
# 🛠️ DEVELOPMENT OVERRIDES
# ==========================================
# When running locally via `go run`, you can override these.
# They are safely ignored by Docker if not set.
# DB_DSN=postgres://user:password@localhost:5432/dbname?sslmode=disable
# PORT=8080
# LOCALES_DIR=locales



# ==========================================
# 🗄️ DATABASE SECRETS
# ==========================================
# e.g. tivri_user
POSTGRES_USER=
# e.g. super_secret_db_password
POSTGRES_PASSWORD=
# e.g. tivri_production
POSTGRES_DB=

# ==========================================
# 🛡️ ADMIN PANEL CREDENTIALS
# ==========================================
# e.g. admin
ADMIN_USERNAME=
# e.g. change_this_immediately
ADMIN_PASSWORD=

# ==========================================
# 🤖 BOT PROTECTION (Cloudflare Turnstile)
# ==========================================
# e.g. 1x00000000000000000000AA
TURNSTILE_SITE_KEY=
# e.g. 1x0000000000000000000000000000000AA
TURNSTILE_SECRET_KEY=

# ==========================================
# 📬 NOTIFICATIONS (Telegram Worker)
# ==========================================
# e.g. 123456789:ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghi
TELEGRAM_BOT_TOKEN=
# e.g. -1001234567890
TELEGRAM_CHAT_ID=

# ==========================================
# 📊 ANALYTICS
# ==========================================
# Use a dummy string locally to verify integration without skewing production stats.
# e.g. dummy-token-for-local-dev
CLOUDFLARE_INSIGHTS_TOKEN=

# ==========================================
# 🔐 CRYPTOGRAPHY
# ==========================================
# The CSRF token used for session security. 
# MUST be exactly 32 bytes (32 random characters).
# e.g. 1234567890abcdef1234567890abcdef
CSRF_AUTH_KEY=
